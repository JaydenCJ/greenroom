# Greenroom configuration. Copy to .env and edit. Never commit your .env.

# ---- Required ---------------------------------------------------------------

# Shared secret configured on the GitHub App / webhook.
# Generate one with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# Base domain for preview URLs. Point a wildcard DNS record
# (*.preview.example.com) at this server.
BASE_DOMAIN=preview.example.com

# ---- GitHub API (PR comments + closed-PR detection) --------------------------

# Fine-grained PAT or GitHub App installation token with "pull requests: read"
# and "issues: write" on the target repos. Leave empty to disable PR comments;
# environments still deploy and the TTL reaper still works.
GITHUB_TOKEN=

# ---- Optional (defaults shown) ------------------------------------------------

# Environment lifetime after the last deploy, in hours.
#TTL_HOURS=72

# Minutes between reaper scans for expired or closed-PR environments.
#REAPER_INTERVAL_MINUTES=10

# Host port range allocated to preview environments.
#PORT_RANGE=20000-20100

# Basic auth protecting every preview URL. If BASIC_AUTH_PASSWORD is empty,
# greenroom generates a random password at first start and prints it once.
#BASIC_AUTH_USER=preview
#BASIC_AUTH_PASSWORD=

# Comma-separated owner/repo allowlist. Empty allows every repo that passes
# webhook signature verification.
#ALLOWED_REPOS=your-org/app,your-org/api

# Compose file path inside each target repository.
#COMPOSE_FILE=docker-compose.yml

# Host Caddy uses to reach preview ports. The default 127.0.0.1 is correct
# both for the bundled compose stack (its Caddy uses host networking) and
# for a Caddy installed directly on the host. Only change it if you run
# Caddy as a bridge-networked container (e.g. host.docker.internal).
#PROXY_UPSTREAM_HOST=127.0.0.1

# Address preview containers publish their port on (passed to target compose
# files as GREENROOM_BIND). Keep 127.0.0.1: with the bundled stack Caddy
# reaches previews over loopback. Only widen this (e.g. to a Docker bridge
# IP such as 172.17.0.1, plus a firewall on the range) if your reverse proxy
# cannot reach loopback.
#PREVIEW_BIND_HOST=127.0.0.1

# Command greenroom runs after writing or removing a Caddy site snippet so
# Caddy picks up the change. The bundled compose stack defaults to
# "docker exec greenroom-caddy caddy reload --config /etc/caddy/Caddyfile".
# With a host-managed Caddy use something like
# "caddy reload --config /etc/caddy/Caddyfile" or "systemctl reload caddy".
# Empty disables the automatic reload (you must reload Caddy yourself).
#CADDY_RELOAD_CMD=

# ---- Bundled Caddy (docker-compose.yml) ---------------------------------------

# Email for Let's Encrypt registration.
#ACME_EMAIL=you@example.com

# Public hostname for greenroom's own webhook endpoint.
#GREENROOM_PUBLIC_HOST=greenroom.example.com
